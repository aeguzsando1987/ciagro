# .env.example — Copiar a .env y ajustar valores
# Base de datos
POSTGRES_DB=ciagro_db_alpha_v1
POSTGRES_USER=ciagro_user
POSTGRES_PASSWORD=ciagro_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=cambiar-en-produccion-usar-django-get-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Redis / Celery
REDIS_URL=redis://redis:6379/0
